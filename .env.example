# Public API base URL (no trailing slash). Used for SSR and for detecting local vs prod.
# In the browser, requests to http://localhost or 127.0.0.1 are sent via same-origin
# /api/backend/* (see next.config rewrites) to avoid CORS against the Next dev server.
# Local API port must match your backend (Swagger often uses 5001). Browser calls use /api/backend → API_PROXY_TARGET.
NEXT_PUBLIC_API_URL=http://127.0.0.1:5001

# Where Next.js forwards /api/backend/* (server-side rewrite). Use host.docker.internal if Next runs in Docker.
# API_PROXY_TARGET=http://127.0.0.1:5001

NEXT_PUBLIC_APP_NAME=Nsuo

# Platform super-admin UI: /platform/organisations (JWT must include isPlatformSuperAdmin).
# Use backend seed credentials for POST /auth/login — see AquaFarm API seeds (e.g. saas-superadmin@…).
