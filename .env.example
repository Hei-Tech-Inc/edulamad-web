# Public API base URL (no trailing slash). Used for SSR and for detecting local vs prod.
# In the browser, requests to http://localhost or 127.0.0.1 are sent via same-origin
# /api/backend/* (see next.config rewrites) to avoid CORS against the Next dev server.
# EDULAMAD API default local port is often 5003 — match your running backend.
NEXT_PUBLIC_API_URL=http://127.0.0.1:5003

# Optional: force /api/backend/* proxy target (overrides derivation from NEXT_PUBLIC_API_URL).
# Use host.docker.internal if Next runs in Docker.
API_PROXY_TARGET=http://127.0.0.1:5003

NEXT_PUBLIC_APP_NAME=Edulamad

# --- NextAuth (social login) ---
# Public URL of this Next app (OAuth redirect callbacks). Must match the URL users open in the browser.
NEXTAUTH_URL=http://localhost:3000
# openssl rand -base64 32
NEXTAUTH_SECRET=

# Google OAuth (NextAuth). Authorized redirect URI in Google Cloud Console:
#   {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: GitHub OAuth — authorized callback URL: {NEXTAUTH_URL}/api/auth/callback/github
# GITHUB_ID=
# GITHUB_SECRET=

# Server-side calls from NextAuth route to your API (defaults to NEXT_PUBLIC_API_URL if unset).
# Use when the browser uses /api/backend proxy but the Node server must hit the API directly.
# API_SERVER_URL=http://127.0.0.1:5003

# Browser URL for this Next app (links, OAuth callbacks). Default dev: http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAPI JSON for /developer/api-reference (optional). Tries NEXT_PUBLIC_OPENAPI_SPEC_URL if set,
# else fetches from getApiBaseURL() + NEXT_PUBLIC_OPENAPI_SPEC_PATH (default /api-json), then
# /openapi.json, /docs-json, etc. Falls back to contexts/api-docs.json when the API is offline.
# NEXT_PUBLIC_OPENAPI_SPEC_PATH=/api-json
# NEXT_PUBLIC_OPENAPI_SPEC_URL=https://api.example.com/custom-openapi.json

# OneSignal web push app id.
# NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# Platform super-admin UI: /platform/organisations (JWT must include isPlatformSuperAdmin).
# Use backend seed credentials for POST /auth/login — see AquaFarm API seeds (e.g. saas-superadmin@…).
